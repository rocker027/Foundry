{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Foundry Skill Manifest",
  "type": "object",
  "required": ["slug", "current_version", "adopted_at", "locked", "evolution_policy", "versions"],
  "properties": {
    "slug": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
    "current_version": { "type": "integer", "minimum": 1 },
    "adopted_at": { "type": "string", "format": "date-time" },
    "locked": { "type": "boolean" },
    "evolution_policy": { "type": "string", "enum": ["human_gated"] },
    "versions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["version", "created_at", "evolution_type"],
        "properties": {
          "version": { "type": "integer" },
          "created_at": { "type": "string" },
          "evolution_type": {
            "type": "string",
            "enum": ["ADOPTED", "CAPTURED", "FIX", "DERIVED", "ROLLBACK"]
          },
          "session_id": { "type": ["string", "null"] },
          "experience_id": { "type": ["string", "null"] },
          "summary": { "type": "string" },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
        }
      }
    }
  },
  "additionalProperties": true
}
